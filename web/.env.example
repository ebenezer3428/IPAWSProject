# For local dev with Vite proxy, leave empty or unset.
# For Firebase Hosting production, set this to your backend base URL.
VITE_API_BASE_URL=https://your-api-domain.example.com

# Firebase web config for Google Sign-In.
# Find these in the Firebase Console -> Project settings -> General ->
# "Your apps" -> SDK setup and configuration. The apiKey is a public client
# identifier (not a secret) and is safe to ship in the frontend bundle.
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

